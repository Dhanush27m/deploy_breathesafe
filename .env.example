# ─────────────────────────────────────────────────────────────────────────────
# BreatheSafe — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=true
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=breathesafe
POSTGRES_USER=breathesafe
POSTGRES_PASSWORD=breathesafe_secret_change_me

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Supabase / Remote Database (used by load_csv_to_db.py and sync_csv.py) ───
# Get from: Supabase dashboard → Settings → Database → Connection string (URI)
SUPABASE_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# ── Local Database URLs (used by load_csv_to_db.py --local / --local-deploy) ─
LOCAL_DEV_DATABASE_URL=postgresql://breathesafe:<password>@localhost:5432/breathesafe
LOCAL_DEPLOY_DATABASE_URL=postgresql://breathesafe:<password>@localhost:5434/breathesafe_deploy

# ── OpenAQ API (free — get key at https://api.openaq.org/register) ─────────
# Leave blank to use anonymous rate limits (100 req/hour)
OPENAQ_API_KEY=

# ── OpenWeatherMap (free — get key at https://openweathermap.org/api) ────────
OPENWEATHER_API_KEY=

# ── Open-Meteo: No key needed! Used for temperature + wind speed ──────────────

# ── Email Notifications (Gmail App Password) ──────────────────────────────────
# Setup: Google Account → Security → 2-Step Verification → App Passwords
# Create an App Password for "Mail" → copy the 16-character password below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Scheduler ────────────────────────────────────────────────────────────────
AQI_FETCH_INTERVAL_MINUTES=60
ALERT_CHECK_INTERVAL_MINUTES=30
